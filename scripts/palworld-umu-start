#!/usr/bin/env python3
import argparse,base64,json,os,re,shutil,signal,subprocess,sys,threading,time
from pathlib import Path
from urllib.error import HTTPError,URLError
from urllib.request import Request,urlopen

VERSION="0.2.8"
HOME=Path("/home/container")
EXE=HOME/"Pal/Binaries/Linux/PalServer-Linux-Shipping"
PARSER=HOME/"PalworldServerConfigParser"
DEFAULT_INI=HOME/"DefaultPalWorldSettings.ini"
CONFIG_DIR=HOME/"Pal/Saved/Config/LinuxServer"
CONFIG=CONFIG_DIR/"PalWorldSettings.ini"
WINDOWS_CONFIG=HOME/"Pal/Saved/Config/WindowsServer/PalWorldSettings.ini"
SAVE_ROOT=HOME/"Pal/Saved"
SAVE_GAMES=SAVE_ROOT/"SaveGames"
BACKUP_ROOT=HOME/".loryvant-backups"
REST_HOST="127.0.0.1"
READY_TIMEOUT=120
REST_TIMEOUT=3
SECRET_LINE=re.compile(r"^(.*Password.*(?:value:|with value:)).*$",re.I)

server=None
stop_event=threading.Event()
rest_lock=threading.Lock()

def out(message): print(f"[Loryvant] {message}",flush=True)
def warn(message): print(f"[Loryvant] WARNUNG: {message}",file=sys.stderr,flush=True)
def err(message): print(f"[Loryvant] FEHLER: {message}",file=sys.stderr,flush=True)
def fail(message,code): err(message);raise SystemExit(code)
def enabled(name,default="0"): return os.environ.get(name,default).strip().lower() in {"1","true","yes","on"}

def need_file(path,label,code,executable=False):
    if not path.is_file() or executable and not os.access(path,os.X_OK): fail(f"{label} fehlt: {path}",code)

def admin_password():
    value=os.environ.get("ADMIN_PASSWORD","")
    if not value: fail("ADMIN_PASSWORD ist leer.",61)
    return value

def rest_port():
    value=os.environ.get("REST_API_PORT","8212").strip()
    if not value.isdigit() or not 1<=int(value)<=65535: fail(f"REST_API_PORT ist ungültig: {value}",63)
    return value

def environment():
    env=os.environ.copy()
    paths=[str(HOME/"linux64"),str(HOME/"Pal/Binaries/Linux")]
    if env.get("LD_LIBRARY_PATH","").strip(): paths.append(env["LD_LIBRARY_PATH"])
    env.update({
        "HOME":str(HOME),"USER":"container","SteamAppId":"2394010","SteamGameId":"2394010",
        "LD_LIBRARY_PATH":":".join(paths),"REST_API_ENABLED":"True","REST_API_PORT":rest_port(),
        "RCON_ENABLE":"False","LOG_FORMAT_TYPE":"Text",
    })
    for key in (
        "PROTONPATH","WINEPREFIX","WINEDLLOVERRIDES","RUNTIMEPATH","UMU_NO_RUNTIME",
        "UMU_NO_PROTON","UMU_CONTAINER_NSENTER","PROTON_LOG","PROTON_LOG_DIR","UMU_LOG",
        "DISPLAY","WAYLAND_DISPLAY","XDG_SESSION_TYPE","SDL_VIDEODRIVER",
    ): env.pop(key,None)
    return env

def prepare_directories():
    for path in (CONFIG_DIR,SAVE_GAMES,BACKUP_ROOT): path.mkdir(parents=True,exist_ok=True)

def migrate_configuration():
    if CONFIG.is_file() and CONFIG.stat().st_size>0: return
    if WINDOWS_CONFIG.is_file() and WINDOWS_CONFIG.stat().st_size>0:
        stamp=time.strftime("%Y%m%dT%H%M%SZ",time.gmtime())
        backup=BACKUP_ROOT/f"PalWorldSettings-WindowsServer-{stamp}.ini"
        shutil.copy2(WINDOWS_CONFIG,backup);shutil.copy2(WINDOWS_CONFIG,CONFIG)
        out("WindowsServer-Konfiguration wurde nach LinuxServer übernommen.")
        out(f"Konfigurationssicherung: {backup}")
        return
    shutil.copy2(DEFAULT_INI,CONFIG)
    out("LinuxServer/PalWorldSettings.ini wurde aus der Vorlage angelegt.")

def update_server(env):
    if not enabled("AUTO_UPDATE","1"):
        out("Automatisches SteamCMD-Update übersprungen.");return
    steamcmd=HOME/"steamcmd/steamcmd.sh"
    if not steamcmd.is_file():
        warn(f"SteamCMD fehlt; Update übersprungen: {steamcmd}");return
    user=os.environ.get("STEAM_USER","").strip() or "anonymous"
    command=[str(steamcmd),"+force_install_dir",str(HOME),"+login",user]
    if user!="anonymous":
        command.append(os.environ.get("STEAM_PASS",""))
        auth=os.environ.get("STEAM_AUTH","")
        if auth: command.append(auth)
    command.extend(["+@sSteamCmdForcePlatformType","linux","+app_update","2394010","+quit"])
    out("Prüfe SteamCMD-Updates für den nativen Linux-Server.")
    result=subprocess.run(command,cwd=steamcmd.parent,env=env,check=False)
    if result.returncode: fail(f"SteamCMD-Update fehlgeschlagen, Exit {result.returncode}.",39)

def run_parser(env):
    migrate_configuration()
    result=subprocess.run([str(PARSER)],cwd=HOME,env=env,text=True,stdout=subprocess.PIPE,stderr=subprocess.STDOUT)
    output=result.stdout or ""
    for line in output.splitlines():
        match=SECRET_LINE.match(line)
        print(f"{match.group(1)} <redacted>" if match else line,flush=True)
    if result.returncode or "INI file updated successfully." not in output:
        fail(f"Config-Parser fehlgeschlagen, Exit {result.returncode}.",40)
    required=("RESTAPIEnabled with value: True",f"RESTAPIPort with value: {env['REST_API_PORT']}","RCONEnabled with value: False")
    if any(item not in output for item in required): fail("Config-Parser hat das REST-Profil unvollständig angewendet.",64)

def writable(path,name,code):
    probe=path/name
    try: probe.touch(exist_ok=False);probe.unlink()
    except OSError as exc: fail(f"Pfad ist nicht beschreibbar: {path} ({exc})",code)

def prepare_storage():
    subprocess.run(["chmod","-R","u+rwX",str(SAVE_ROOT)],check=True)
    writable(SAVE_GAMES,".loryvant-save-write-test",42)
    writable(CONFIG_DIR,".loryvant-config-write-test",45)

def rest(endpoint,method="GET",payload=None,timeout=REST_TIMEOUT):
    credentials=base64.b64encode(f"admin:{admin_password()}".encode()).decode()
    headers={"Accept":"application/json","Authorization":f"Basic {credentials}"}
    data=None
    if payload is not None:
        data=json.dumps(payload,separators=(",",":")).encode();headers["Content-Type"]="application/json"
    request=Request(f"http://{REST_HOST}:{rest_port()}/v1/api/{endpoint.lstrip('/')}",data=data,headers=headers,method=method)
    with rest_lock:
        try:
            with urlopen(request,timeout=timeout) as response: status=response.status;body=response.read()
        except HTTPError as exc: status=exc.code;body=exc.read()
        except (URLError,TimeoutError,OSError): return 0,None
    if not body: return status,None
    try: return status,json.loads(body.decode(errors="replace"))
    except json.JSONDecodeError: return status,body.decode(errors="replace")

def readiness_worker(started):
    deadline=started+READY_TIMEOUT;next_status=started+15
    while not stop_event.is_set():
        if server is not None and server.poll() is not None: return
        status,body=rest("info")
        if status==200 and isinstance(body,dict) and body.get("version"):
            elapsed=time.monotonic()-started
            out("Palworld ist bereit.");out(f"Startdauer des Palworld-Prozesses: {elapsed:.1f} Sekunden.")
            out(f"REST-Info: {body.get('version')} | {body.get('servername','Server')}");return
        now=time.monotonic()
        if now>=deadline: err(f"REST-API wurde innerhalb von {READY_TIMEOUT} Sekunden nicht bereit.");return
        if now>=next_status:
            out(f"Palworld-Prozess läuft; REST-API noch nicht bereit ({int(now-started)} Sekunden).");next_status+=15
        if stop_event.wait(2): return

def print_json(value): print(json.dumps(value,ensure_ascii=False,indent=2,sort_keys=True),flush=True)
def seconds(value,default=5):
    try: return max(0,min(3600,int(value)))
    except ValueError: return default

def console(command):
    parts=command.split();name=parts[0].lower();args=parts[1:]
    if name in {"help","?"}:
        print("REST-Kommandos: info, showinfo, showplayers, settings, metrics, save, broadcast <Text>, kickplayer <ID> [Text], banplayer <ID> [Text], unbanplayer <ID>, shutdown [Sekunden] [Text], doexit",flush=True);return
    endpoint="";method="GET";payload=None
    if name in {"info","showinfo"}: endpoint="info"
    elif name in {"showplayers","players"}: endpoint="players"
    elif name in {"settings","metrics"}: endpoint=name
    elif name=="save": endpoint="save";method="POST"
    elif name in {"broadcast","announce"}:
        endpoint="announce";method="POST";payload={"message":" ".join(args).strip()}
        if not payload["message"]: err("Broadcast benötigt einen Nachrichtentext.");return
    elif name in {"kickplayer","kick","banplayer","ban"} and args:
        endpoint="kick" if name in {"kickplayer","kick"} else "ban";method="POST"
        payload={"userid":args[0],"message":" ".join(args[1:]).strip()}
    elif name in {"unbanplayer","unban"} and args: endpoint="unban";method="POST";payload={"userid":args[0]}
    elif name=="shutdown":
        endpoint="shutdown";method="POST";wait=seconds(args[0]) if args else 5
        payload={"waittime":wait,"message":" ".join(args[1:] if args else []).strip() or "Server wird beendet."}
    elif name in {"doexit","stop"}: endpoint="stop";method="POST"
    else: err(f"Unbekanntes Konsolenkommando: {command}");return
    status,body=rest(endpoint,method,payload,10)
    if status==200:
        if body is not None: print_json(body)
        else: out(f"REST-Kommando erfolgreich: {name}")
    elif status==401: err("REST-Authentifizierung fehlgeschlagen.")
    elif status: err(f"REST-Kommando {name} lieferte HTTP {status}.")
    else: err(f"REST-Zeitüberschreitung für Kommando: {command}")

def console_worker():
    for line in sys.stdin:
        if stop_event.is_set(): return
        command=line.strip()
        if command: console(command)

def server_command():
    port=os.environ.get("SERVER_PORT","8211")
    command=[str(EXE),"Pal","-publiclobby",f"-port={port}",f"-publicport={port}",f"-players={os.environ.get('MAX_PLAYERS','32')}","-logformat=text"]
    public_ip=os.environ.get("PUBLIC_IP","").strip()
    if public_ip: command.insert(-1,f"-publicip={public_ip}")
    return command

def validate_profile():
    command=server_command()
    forbidden={"-rcon","-useperfthreads","-NoAsyncLoadingThread","-UseMultithreadForDS","umu-run"}
    present=forbidden.intersection(command)
    if present: fail(f"Unerwünschte Palworld-Argumente aktiv: {', '.join(sorted(present))}",1)
    if command[0]!=str(EXE) or command[1]!="Pal": fail("Nativer Linux-Startpfad ist ungültig.",1)
    if "-logformat=text" not in command: fail("Palworld-Textlogging fehlt.",1)
    if rest_port()==os.environ.get("SERVER_PORT","8211"): fail("REST_API_PORT kollidiert mit SERVER_PORT.",1)

def handle_signal(signum,_frame):
    stop_event.set()
    if server is not None and server.poll() is None:
        try: os.killpg(server.pid,signum)
        except ProcessLookupError: pass

def cleanup():
    stop_event.set()
    if server is not None and server.poll() is None:
        handle_signal(signal.SIGTERM,None)
        try: server.wait(timeout=15)
        except subprocess.TimeoutExpired:
            try: os.killpg(server.pid,signal.SIGKILL)
            except ProcessLookupError: pass

def preflight():
    if shutil.which("getconf") is None: fail("getconf fehlt im Containerimage.",1)
    validate_profile()
    value=subprocess.run(["getconf","GNU_LIBC_VERSION"],text=True,capture_output=True,check=True).stdout.strip()
    out(f"Launcher-Selbsttest bestanden: v{VERSION}, nativer Linux-Server, {value}, REST-Port {rest_port()}")
    return 0

def main():
    parser=argparse.ArgumentParser();parser.add_argument("--version",action="store_true");parser.add_argument("--self-test",action="store_true");args=parser.parse_args()
    if args.version: print(f"palworld-umu-start {VERSION}");return 0
    if args.self_test: return preflight()
    env=environment()
    need_file(PARSER,"PalworldServerConfigParser",40,True);need_file(DEFAULT_INI,"DefaultPalWorldSettings.ini",47)
    admin_password();validate_profile();prepare_directories();update_server(env)
    need_file(EXE,"nativer Palworld-Linuxserver",48,True);run_parser(env);prepare_storage()
    command=server_command()
    out(f"Egg v{VERSION}");out("Runtime: nativer Palworld Linux Dedicated Server");out("Kompatibilitätsschicht: entfällt")
    out(f"Save-Pfad ist beschreibbar: {SAVE_GAMES}");out(f"Lokale REST-API: {REST_HOST}:{env['REST_API_PORT']}")
    out(f"Palworld-Argumente: {' '.join(command[2:])}")
    for sig in (signal.SIGTERM,signal.SIGINT): signal.signal(sig,handle_signal)
    global server
    started=time.monotonic();server=subprocess.Popen(command,env=env,cwd=HOME,start_new_session=True)
    threading.Thread(target=readiness_worker,args=(started,),name="rest-readiness",daemon=True).start()
    threading.Thread(target=console_worker,name="stdin-rest",daemon=True).start()
    return server.wait()

if __name__=="__main__":
    try: raise SystemExit(main())
    finally: cleanup()
