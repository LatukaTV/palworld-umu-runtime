#!/usr/bin/env python3
import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import time
from pathlib import Path

VERSION = "0.2.15"
EXPECTED_WINE = "wine-11.13"
CORE = Path("/usr/local/bin/palworld-umu-start-core")
HOME = Path("/home/container")
SAVE_ROOT = HOME / "ModdedServer/Pal/Saved"
SAVE_GAMES = SAVE_ROOT / "SaveGames/0"
GAME_USER_SETTINGS = SAVE_ROOT / "Config/WindowsServer/GameUserSettings.ini"
BACKUP_ROOT = HOME / ".loryvant-backups/saves"
MARKER = SAVE_ROOT / ".loryvant-v0.2.12-backup-tree-reset"
WINE_PREFIX = HOME / ".wine-palworld-modded"
WINE_BACKUP_ROOT = HOME / ".loryvant-backups/wine-prefixes"
WINE_MARKER = WINE_PREFIX / ".loryvant-wine-version"
WINE_SYSTEM_REG = WINE_PREFIX / "system.reg"
WINE_KERNEL32 = WINE_PREFIX / "drive_c/windows/system32/kernel32.dll"
DEDICATED_NAME = re.compile(r"^\s*DedicatedServerName\s*=\s*([^\r\n]+)", re.I | re.M)


def out(message):
    print(f"[Loryvant] {message}", flush=True)


def warn(message):
    print(f"[Loryvant] WARNUNG: {message}", file=sys.stderr, flush=True)


def enabled(name, default="0"):
    return os.environ.get(name, default).strip().lower() in {"1", "true", "yes", "on"}


def wine_version():
    result = subprocess.run(
        ["wine64", "--version"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    value = (result.stdout or "").strip()
    if result.returncode or value != EXPECTED_WINE:
        raise SystemExit(
            f"[Loryvant] FEHLER: Wine-Laufzeit stimmt nicht: erwartet {EXPECTED_WINE}, erhalten {value or '<leer>'}."
        )
    return value


def unique_backup_path(root, base):
    candidate = root / base
    counter = 1
    while candidate.exists() or candidate.is_symlink():
        candidate = root / f"{base}-{counter}"
        counter += 1
    return candidate


def preserve_wine_prefix(reason):
    WINE_BACKUP_ROOT.mkdir(parents=True, exist_ok=True)
    stamp = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime())
    target = unique_backup_path(WINE_BACKUP_ROOT, f"wine-prefix-{reason}-{stamp}")
    shutil.move(str(WINE_PREFIX), str(target))
    out(f"Vorheriger Wine-Prefix wurde erhalten: {target}")


def wine_prefix_usable():
    if not WINE_SYSTEM_REG.is_file() or not WINE_KERNEL32.is_file():
        return False
    env = os.environ.copy()
    env.update({
        "HOME": str(HOME),
        "USER": "container",
        "WINEPREFIX": str(WINE_PREFIX),
        "WINEARCH": "win64",
        "WINEDEBUG": "-all",
    })
    try:
        result = subprocess.run(
            ["wine64", "cmd", "/c", "exit", "0"],
            env=env,
            cwd=HOME,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=30,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        warn(f"Wine-Prefix-Funktionstest fehlgeschlagen: {exc}")
        return False
    finally:
        subprocess.run(
            ["wineserver", "-k"],
            env=env,
            cwd=HOME,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=15,
            check=False,
        )
    if result.returncode:
        detail = (result.stdout or "").strip().splitlines()
        if detail:
            warn(f"Wine-Prefix-Funktionstest: {detail[-1]}")
        return False
    return True


def prepare_wine_runtime():
    actual = wine_version()
    previous = ""
    try:
        previous = WINE_MARKER.read_text(encoding="utf-8").strip()
    except OSError:
        pass
    reset_requested = enabled("RESET_WINE_PREFIX")
    if WINE_PREFIX.is_symlink():
        raise SystemExit("[Loryvant] FEHLER: Wine-Prefix darf kein symbolischer Link sein.")
    incomplete = WINE_PREFIX.exists() and not (
        WINE_SYSTEM_REG.is_file() and WINE_KERNEL32.is_file()
    )
    unusable = (
        WINE_PREFIX.exists()
        and not incomplete
        and previous == actual
        and not reset_requested
        and not wine_prefix_usable()
    )
    if WINE_PREFIX.exists() and (previous != actual or reset_requested or incomplete or unusable):
        if reset_requested:
            reason = "manual-reset"
        elif incomplete:
            reason = "incomplete"
        elif unusable:
            reason = "unusable"
        else:
            reason = f"before-{actual}"
        preserve_wine_prefix(reason)
    WINE_PREFIX.mkdir(parents=True, exist_ok=True)
    temporary = WINE_MARKER.with_suffix(".tmp")
    temporary.write_text(actual + "\n", encoding="utf-8")
    os.replace(temporary, WINE_MARKER)
    os.environ["RESET_WINE_PREFIX"] = "0"
    out(f"Wine-Laufzeit bereit: {actual}")


def read_world_name():
    try:
        text = GAME_USER_SETTINGS.read_text(encoding="utf-8-sig", errors="replace")
    except OSError:
        text = ""
    match = DEDICATED_NAME.search(text)
    if match:
        name = match.group(1).strip()
        candidate = SAVE_GAMES / name
        if re.fullmatch(r"[A-Za-z0-9_-]+", name) and candidate.is_dir():
            return name
    records = []
    if SAVE_GAMES.is_dir():
        for path in SAVE_GAMES.iterdir():
            if not path.is_dir():
                continue
            files = [path / "Level.sav", path / "LevelMeta.sav"]
            existing = [item for item in files if item.is_file()]
            if existing:
                records.append((max(item.stat().st_mtime for item in existing), path.name))
    return max(records)[1] if records else ""


def validate_backup_tree(path):
    local = path / "local"
    world = path / "world"
    local.mkdir(parents=True, exist_ok=True)
    world.mkdir(parents=True, exist_ok=True)
    source = world / ".loryvant-copy-source.tmp"
    copied = local / ".loryvant-copy-target.tmp"
    renamed = local / ".loryvant-copy-final.tmp"
    try:
        source.write_bytes(b"loryvant-palworld-save")
        shutil.copy2(source, copied)
        os.replace(copied, renamed)
        if renamed.read_bytes() != b"loryvant-palworld-save":
            raise OSError("Kopiertest lieferte abweichende Daten")
    finally:
        for item in (source, copied, renamed):
            item.unlink(missing_ok=True)


def reset_backup_tree():
    if MARKER.is_file() and not enabled("RESET_WORLD_BACKUP_TREE"):
        out("Windows-Backup-Unterbaum wurde für v0.2.12 bereits bereinigt.")
        return
    world_name = read_world_name()
    if not world_name:
        warn("Backup-Unterbaum bleibt unverändert: aktive Welt wurde noch nicht ermittelt.")
        return
    world_root = SAVE_GAMES / world_name
    backup_tree = world_root / "backup"
    BACKUP_ROOT.mkdir(parents=True, exist_ok=True)
    stamp = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime())
    preserved = ""
    if backup_tree.exists() or backup_tree.is_symlink():
        target = unique_backup_path(BACKUP_ROOT, f"generated-backup-tree-{world_name}-{stamp}")
        shutil.move(str(backup_tree), str(target))
        preserved = str(target)
        out(f"Alter generierter Backup-Unterbaum wurde erhalten: {target}")
    backup_tree.mkdir(parents=True, exist_ok=True)
    (backup_tree / "local").mkdir(parents=True, exist_ok=True)
    (backup_tree / "world").mkdir(parents=True, exist_ok=True)
    for path in (backup_tree, backup_tree / "local", backup_tree / "world"):
        path.chmod(0o755)
    validate_backup_tree(backup_tree)
    MARKER.parent.mkdir(parents=True, exist_ok=True)
    temporary = MARKER.with_suffix(".tmp")
    temporary.write_text(json.dumps({
        "version": "0.2.12",
        "world": world_name,
        "created": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "preserved": preserved,
    }, ensure_ascii=False, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(temporary, MARKER)
    out(f"Frischer Windows-Backup-Unterbaum geprüft: {backup_tree}")


def self_test():
    if not CORE.is_file() or not os.access(CORE, os.X_OK):
        raise SystemExit("palworld-umu-start-core fehlt oder ist nicht ausführbar")
    actual = wine_version()
    out(f"Wrapper-Selbsttest bestanden: v{VERSION}, {actual}, funktionaler Prefix-Test und Backup-Unterbaum-Reset")
    return 0


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--version", action="store_true")
    parser.add_argument("--self-test", action="store_true")
    args, rest = parser.parse_known_args()
    if args.version:
        print(f"palworld-umu-start {VERSION}")
        return 0
    if args.self_test:
        return self_test()
    prepare_wine_runtime()
    reset_backup_tree()
    os.execv(str(CORE), [str(CORE), *rest])


if __name__ == "__main__":
    raise SystemExit(main())
