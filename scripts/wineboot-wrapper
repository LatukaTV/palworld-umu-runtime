#!/usr/bin/env bash
set +e

prefix="${WINEPREFIX:-${HOME:-/home/container}/.wine}"
system_reg="${prefix}/system.reg"
kernel64="${prefix}/drive_c/windows/system32/kernel32.dll"
cmd64="${prefix}/drive_c/windows/system32/cmd.exe"
probe_log="/tmp/loryvant-wineboot-probe.$$.log"

cleanup() {
    rm -f "${probe_log}"
}
trap cleanup EXIT

prefix_complete() {
    [[ -s "${system_reg}" && -s "${kernel64}" && -s "${cmd64}" ]]
}

prefix_usable() {
    prefix_complete || return 1
    timeout 8 env \
        WINEPREFIX="${prefix}" \
        WINEARCH=win64 \
        WINEDEBUG=-all \
        /usr/local/bin/wine64 'C:\windows\system32\cmd.exe' /c exit 0 \
        >"${probe_log}" 2>&1
}

report_missing() {
    for path in "${system_reg}" "${kernel64}" "${cmd64}"; do
        [[ -s "${path}" ]] || printf '[Loryvant] FEHLT: %s\n' "${path}" >&2
    done
}

stop_wine() {
    env WINEPREFIX="${prefix}" wineserver -k >/dev/null 2>&1 || true
    for _ in $(seq 1 100); do
        kill -0 "${boot_pid}" >/dev/null 2>&1 || break
        sleep .1
    done
    if kill -0 "${boot_pid}" >/dev/null 2>&1; then
        kill -TERM "${boot_pid}" >/dev/null 2>&1 || true
    fi
    if [[ -z "${boot_rc}" ]]; then
        wait "${boot_pid}" >/dev/null 2>&1
        boot_rc=$?
    fi
    env WINEPREFIX="${prefix}" wineserver -w >/dev/null 2>&1 || true
}

/usr/local/lib/loryvant/wineboot-real "$@" &
boot_pid=$!
boot_rc=""
usable=0
deadline=$((SECONDS + 120))

while (( SECONDS < deadline )); do
    if prefix_usable; then
        usable=1
        break
    fi
    if [[ -z "${boot_rc}" ]] && ! kill -0 "${boot_pid}" >/dev/null 2>&1; then
        wait "${boot_pid}" >/dev/null 2>&1
        boot_rc=$?
    fi
    sleep .5
done

stop_wine

if [[ "${usable}" -eq 1 ]]; then
    if [[ "${boot_rc:-0}" -ne 0 ]]; then
        printf '[Loryvant] WARNUNG: wineboot meldete Exit %s; der Wine64-Prefix ist funktional ausführbar.\n' "${boot_rc}" >&2
    fi
    exit 0
fi

report_missing
if [[ -s "${probe_log}" ]]; then
    printf '[Loryvant] Letzte Wine64-Prefix-Probe:\n' >&2
    cat "${probe_log}" >&2
fi
if [[ -s "${system_reg}" ]]; then
    printf '[Loryvant] FEHLER: Wine64-Prefix ist nach der Initialisierung nicht funktional ausführbar.\n' >&2
    rm -f "${system_reg}"
fi

if [[ -z "${boot_rc}" || "${boot_rc}" -eq 0 ]]; then
    exit 58
fi
exit "${boot_rc}"
