#!/usr/bin/env bash
set +e

prefix="${WINEPREFIX:-${HOME:-/home/container}/.wine}"
system_reg="${prefix}/system.reg"
kernel64="${prefix}/drive_c/windows/system32/kernel32.dll"
cmd64="${prefix}/drive_c/windows/system32/cmd.exe"

prefix_complete() {
    [[ -s "${system_reg}" && -s "${kernel64}" && -s "${cmd64}" ]]
}

report_missing() {
    for path in "${system_reg}" "${kernel64}" "${cmd64}"; do
        [[ -s "${path}" ]] || printf '[Loryvant] FEHLT: %s\n' "${path}" >&2
    done
}

stop_wine() {
    env WINEPREFIX="${prefix}" wineserver -k >/dev/null 2>&1 || true
    for _ in $(seq 1 100); do
        kill -0 "${boot_pid}" >/dev/null 2>&1 || break
        sleep .1
    done
    if kill -0 "${boot_pid}" >/dev/null 2>&1; then
        kill -TERM "${boot_pid}" >/dev/null 2>&1 || true
    fi
    wait "${boot_pid}" >/dev/null 2>&1
    boot_rc=$?
    env WINEPREFIX="${prefix}" wineserver -w >/dev/null 2>&1 || true
}

/usr/local/lib/loryvant/wineboot-real "$@" &
boot_pid=$!
boot_rc=0

for _ in $(seq 1 1200); do
    if prefix_complete; then
        sleep 2
        stop_wine
        break
    fi
    if ! kill -0 "${boot_pid}" >/dev/null 2>&1; then
        wait "${boot_pid}"
        boot_rc=$?
        break
    fi
    sleep .1
done

if kill -0 "${boot_pid}" >/dev/null 2>&1; then
    stop_wine
    boot_rc=124
fi

if prefix_complete; then
    if [[ "${boot_rc}" -ne 0 ]]; then
        printf '[Loryvant] WARNUNG: wineboot meldete Exit %s; der 64-Bit-Prefix wurde vollständig erzeugt.\n' "${boot_rc}" >&2
    fi
    exit 0
fi

report_missing
if [[ -s "${system_reg}" ]]; then
    printf '[Loryvant] FEHLER: Wine-Prefix ist unvollständig; 64-Bit-Laufzeitdateien fehlen.\n' >&2
    rm -f "${system_reg}"
fi

if [[ "${boot_rc}" -eq 0 ]]; then
    exit 58
fi
exit "${boot_rc}"
